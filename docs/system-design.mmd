%% Diagram: ProxyPay System Architecture
%% Type: Flowchart (top-down)
%% Updated: 2026-04-17

flowchart TD
    client([Client / Merchant App])
    abacate_ext[/"AbacatePay<br/>(PIX provider)"/]
    nauth_ext[/"NAuth<br/>(auth service)"/]
    ztools_ext[/"zTools<br/>(S3, e-mail, utils)"/]

    subgraph api["ProxyPay.API"]
        middleware["TenantMiddleware<br/>(X-Tenant-Id)"]
        controllers["Controllers<br/>Store · Payment · Webhook"]
        swagger["Swagger / OpenAPI"]
    end

    subgraph graphql["ProxyPay.GraphQL"]
        admin_gql["Admin Schema<br/>/graphql (Authorize)<br/>Invoices, Transactions"]
        type_ext["Type Extensions<br/>(InvoiceTypeExtension,<br/>TransactionTypeExtension)"]
    end

    subgraph app["ProxyPay.Application"]
        di["DI Bootstrap<br/>(ConfigureProxyPay)"]
        tenant_ctx["TenantContext<br/>(AsyncLocal + HttpContext)"]
        tenant_res["TenantResolver<br/>(ConnectionString · JwtSecret<br/>· BucketName)"]
        tenant_cat["TenantCatalog<br/>(known tenant IDs)"]
        db_factory["TenantDbContextFactory<br/>(per-request DbContext)"]
        nauth_tenant["NAuthTenantSecretProvider<br/>NAuthTenantProvider"]
    end

    subgraph domain["ProxyPay.Domain"]
        services["Services<br/>Store · Customer · Invoice<br/>Billing · Transaction"]
        models["Models<br/>Store · Customer · Invoice<br/>InvoiceItem · Billing<br/>BillingItem · Transaction"]
    end

    subgraph dto["ProxyPay.DTO"]
        dtos["DTOs &amp; Settings<br/>(AbacatePay, Billing, Invoice,<br/>QRCode, Customer, Store)"]
    end

    subgraph infra_ifaces["ProxyPay.Infra.Interfaces"]
        repo_ifaces["Repository Interfaces<br/>IUnitOfWork"]
    end

    subgraph infra["ProxyPay.Infra"]
        context["ProxyPayContext<br/>(EF Core 9 + Npgsql)"]
        repos["Repositories<br/>(7 per entity)"]
        uow["UnitOfWork"]
        appservices["AppServices<br/>AbacatePayAppService"]
    end

    subgraph tenants["Per-tenant PostgreSQL databases"]
        emagine_db[("emagine")]
        monexup_db[("monexup")]
        fortuno_db[("fortuno")]
    end

    client -->|"REST + X-Tenant-Id"| middleware
    client -->|"GraphQL + X-Tenant-Id"| admin_gql
    middleware --> controllers
    controllers -->|"depend on"| services
    admin_gql --> context
    type_ext -->|"resolves"| ztools_ext
    services --> repo_ifaces
    repos -.implements.-> repo_ifaces
    repos --> context
    services --> appservices
    appservices -->|"HTTPS"| abacate_ext
    abacate_ext -. "POST /webhook/<br/>abacatepay/{tenantId}" .-> controllers
    services --> dtos
    admin_gql --> dtos

    di -->|"registers"| tenant_ctx
    di -->|"registers"| tenant_res
    di -->|"registers"| tenant_cat
    di -->|"registers"| db_factory
    di -->|"registers NAuth"| nauth_tenant

    middleware -->|"sets<br/>HttpContext.Items[TenantId]"| tenant_ctx
    tenant_res -->|"reads current"| tenant_ctx
    tenant_cat -->|"validates"| tenant_res
    db_factory -->|"uses ConnectionString"| tenant_res
    db_factory -->|"creates"| context

    context -->|"Npgsql<br/>(scoped per request)"| emagine_db
    context -->|"Npgsql<br/>(scoped per request)"| monexup_db
    context -->|"Npgsql<br/>(scoped per request)"| fortuno_db

    nauth_tenant -->|"JwtSecret lookup"| nauth_ext
    controllers -->|"Basic auth"| nauth_ext

    style api fill:#4A90D9,stroke:#2C5F8A,color:#fff
    style graphql fill:#E535AB,stroke:#B02888,color:#fff
    style app fill:#7B68EE,stroke:#5A4CBE,color:#fff
    style domain fill:#50C878,stroke:#3A9A5C,color:#fff
    style dto fill:#FF8C00,stroke:#CC7000,color:#fff
    style infra_ifaces fill:#DDA0DD,stroke:#AA70AA,color:#333
    style infra fill:#CD853F,stroke:#A0682F,color:#fff
    style tenants fill:#336791,stroke:#264D6E,color:#fff
    style emagine_db fill:#1f4b6e,stroke:#15354f,color:#fff
    style monexup_db fill:#1f4b6e,stroke:#15354f,color:#fff
    style fortuno_db fill:#1f4b6e,stroke:#15354f,color:#fff
