meta {
  name: Public - Store By Slug
  type: graphql
  seq: 4
}

post {
  url: {{baseUrl}}/graphql
  body: graphql
  auth: none
}

body:graphql {
  {
    storeBySlug(slug: "minha-loja") {
      storeId
      name
      slug
      logo
      logoUrl
      status
      products {
        productId
        name
        price
        imageUrl
      }
      categories {
        categoryId
        name
        productCount
      }
    }
  }
}
