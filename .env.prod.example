# Tenant: emagine (default)
EMAGINE_CONNECTION_STRING=Host=<DB_HOST>;Port=5432;Database=proxypay_prod;Username=<DB_USER>;Password=<DB_PASSWORD>
EMAGINE_JWT_SECRET=<JWT_SECRET_MIN_64_CHARS>

# Tenant: monexup
MONEXUP_CONNECTION_STRING=Host=<DB_HOST>;Port=5432;Database=proxypay_prod;Username=<DB_USER>;Password=<DB_PASSWORD>
MONEXUP_JWT_SECRET=<JWT_SECRET_MIN_64_CHARS>

# AbacatePay
ABACATEPAY_API_KEY=<ABACATEPAY_API_KEY>
ABACATEPAY_WEBHOOK_SECRET=<ABACATEPAY_WEBHOOK_SECRET>
